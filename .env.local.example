# Environment Configuration for Build Optimization

# Build Environment
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
BUILD_STANDALONE=false

# Performance Optimization
ANALYZE=false
NEXT_BUILD_PROFILE=false
NEXT_BUILD_CACHE=true

# Vercel Configuration
VERCEL_ENV=development
VERCEL_URL=localhost:3000

# Database
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Application
NEXT_PUBLIC_APP_NAME=TariffGuard
NEXT_PUBLIC_APP_VERSION=0.1.0

# Development Tools
NEXT_IGNORE_BUILD_ERRORS=false
NEXT_IGNORE_ESLINT_ERRORS=false

# Build Optimization Flags
WEBPACK_BUNDLE_ANALYZER=false
SOURCE_MAPS=false