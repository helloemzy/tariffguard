{
  "name": "manifest-tariff-guard",
  "version": "1.0.0",
  "private": true,
  "description": "Tariff monitoring system for tracking government trade policies and tariff changes",
  "keywords": [
    "tariff",
    "monitoring",
    "trade",
    "government",
    "api",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:standalone": "BUILD_STANDALONE=true next build",
    "build:profile": "next build --profile",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:strict": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:unused": "eslint . --ext .js,.jsx,.ts,.tsx --rule 'unused-imports/no-unused-imports: error'",
    "lint:css": "stylelint \"**/*.css\"",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "clean": "rm -rf .next && rm -rf node_modules && rm -rf .turbo && rm -rf lighthouse-results",
    "clean:cache": "rm -rf .next && rm -rf .eslintcache && rm -rf node_modules/.cache",
    "clean:install": "npm run clean && npm install",
    "clean:build": "rm -rf .next && rm -rf dist && rm -rf out",
    "clean:all": "npm run clean && rm -rf .vercel && rm -rf lighthouse-results && rm -rf build-*.json",
    "validate": "npm run type-check && npm run lint:strict && npm run format:check",
    "validate:full": "npm run type-check && npm run lint:strict && npm run format:check && npm run build",
    "ci": "npm run validate:full",
    "ci:analyze": "npm run validate:full && npm run analyze",
    "ci:performance": "npm run build && npm run perf:lighthouse",
    "precommit": "npm run validate",
    "commit": "git-cz",
    "postinstall": "if [ \"$VERCEL\" != \"1\" ]; then husky || true; fi",
    "prepare": "if [ \"$VERCEL\" != \"1\" ]; then husky; fi",
    "setup-env": "node scripts/setup-env.js",
    "env:setup": "node scripts/setup-env.js",
    "env:validate": "node -e \"require('./src/lib/env.ts'); console.log('✅ Environment validation passed')\"",
    "analyze": "npm run build:analyze && npx @next/bundle-analyzer .next",
    "build:stats": "npm run build && npx webpack-bundle-analyzer .next/static/chunks/*.js",
    "build:optimize": "node scripts/build-optimization.js production --clean",
    "build:optimize:analyze": "node scripts/build-optimization.js analyze --clean",
    "perf:lighthouse": "lhci autorun",
    "perf:build-time": "npm run clean:cache && time npm run build",
    "perf:full": "npm run build:optimize && npm run perf:lighthouse && npm run size-limit",
    "size-limit": "size-limit",
    "size-limit:ci": "size-limit --json > size-limit-report.json",
    "docker:build": "docker build -f Dockerfile.optimized -t tariffguard:latest .",
    "docker:build:analyze": "docker build -f Dockerfile.optimized --target builder -t tariffguard:analyze .",
    "preinstall": "npx only-allow npm",
    "quality:complexity": "plato -r -d quality-reports/complexity src",
    "quality:complexity-simple": "complexity-report -o quality-reports/complexity.json -f json src/",
    "quality:duplicates": "jscpd --reporters html,json --output quality-reports/duplicates src",
    "quality:dependencies": "madge --image quality-reports/dependencies.svg --circular --warning src && depcheck",
    "quality:unused": "unimported --init && unimported",
    "quality:imports": "madge --json quality-reports/imports.json src",
    "quality:type-coverage": "typecov --html --outputDir quality-reports/type-coverage",
    "security:snyk": "snyk test --json > quality-reports/snyk.json || true",
    "security:audit": "audit-ci --config .audit-ci.json",
    "security:retire": "retire --outputformat json --outputpath quality-reports/retire.json --path .",
    "security:all": "npm run security:snyk && npm run security:audit && npm run security:retire",
    "accessibility:axe": "axe http://localhost:3000 --reporter json --output quality-reports/axe.json",
    "accessibility:pa11y": "pa11y --reporter json http://localhost:3000 > quality-reports/pa11y.json",
    "accessibility:unlighthouse": "unlighthouse --site http://localhost:3000 --output quality-reports/unlighthouse",
    "accessibility:all": "npm run accessibility:axe && npm run accessibility:pa11y && npm run accessibility:unlighthouse",
    "performance:lighthouse": "lighthouse http://localhost:3000 --output json --output-path quality-reports/lighthouse.json --chrome-flags=\"--headless\"",
    "performance:bundlesize": "bundlesize",
    "performance:all": "npm run performance:lighthouse && npm run performance:bundlesize && npm run perf:lighthouse",
    "quality:all": "npm run quality:complexity && npm run quality:duplicates && npm run quality:dependencies && npm run quality:unused && npm run quality:type-coverage",
    "quality:report": "node scripts/quality-report.js",
    "quality:full": "npm run quality:all && npm run security:all && npm run quality:report",
    "ci:quality": "npm run validate:full && npm run quality:all && npm run security:all",
    "ci:quality-fast": "npm run lint:strict && npm run type-check && npm run quality:complexity-simple && npm run quality:duplicates"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.0",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.1.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "chart.js": "^4.5.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "nodemailer": "^7.0.6",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.15.4",
    "resend": "^4.0.0",
    "stripe": "^18.5.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "tesseract.js": "^6.0.1",
    "twilio": "^5.3.4",
    "typescript": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.2",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@lhci/cli": "^0.13.0",
    "@next/bundle-analyzer": "^14.2.0",
    "@size-limit/preset-app": "^11.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "audit-ci": "^7.1.0",
    "axe-core": "^4.10.2",
    "bundlesize": "^0.18.1",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "lighthouse": "^12.0.0",
    "lint-staged": "^16.1.5",
    "madge": "^8.0.0",
    "pa11y": "^8.0.0",
    "plato": "^1.7.0",
    "prettier": "^3.2.0",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "retire": "^5.2.4",
    "size-limit": "^11.0.0",
    "snyk": "^1.1293.1",
    "typecov": "^0.2.3",
    "unimported": "^1.31.1",
    "unlighthouse": "^0.17.2",
    "web-vitals": "^4.2.4",
    "webpack-bundle-analyzer": "^4.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "tsc --noEmit"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && node scripts/pre-commit-quality.js",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "size-limit": [
    {
      "name": "Client bundle",
      "path": ".next/static/chunks/**/*.js",
      "limit": "300 kB"
    },
    {
      "name": "Initial JS",
      "path": ".next/static/chunks/pages/_app-*.js",
      "limit": "150 kB"
    }
  ],
  "bundlesize": [
    {
      "path": ".next/static/js/**/*.js",
      "maxSize": "300 kB",
      "compression": "gzip"
    },
    {
      "path": ".next/static/css/**/*.css",
      "maxSize": "50 kB",
      "compression": "gzip"
    }
  ]
}
