# TariffGuard Environment Variables - Production Configuration Template
# Copy to .env.local for development or configure in production deployment

# =================================================================
# BASIC CONFIGURATION
# =================================================================
NODE_ENV=production
NEXT_PUBLIC_DEVELOPMENT_MODE=false
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false

# =================================================================
# APPLICATION URLS
# =================================================================
NEXT_PUBLIC_APP_NAME="TariffGuard - Preston Steel Import Monitor"
NEXT_PUBLIC_APP_URL=https://tariffguard.vercel.app
NEXT_PUBLIC_API_URL=https://tariffguard.vercel.app/api
NEXTAUTH_URL=https://tariffguard.vercel.app

# =================================================================
# SUPABASE CONFIGURATION
# =================================================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =================================================================
# SECURITY KEYS
# =================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_32_chars_minimum
JWT_SECRET=your_jwt_secret_32_chars_minimum
ENCRYPTION_KEY=exactly_32_character_encryption_key
CRYPTO_SALT=at_least_16_character_crypto_salt

# =================================================================
# FEDERAL REGISTER API
# =================================================================
NEXT_PUBLIC_FEDERAL_REGISTER_API_URL=https://www.federalregister.gov/api/v1
FEDERAL_REGISTER_API_KEY=optional_api_key

# =================================================================
# USITC DATAWEB API
# =================================================================
# USITC DataWeb credentials (Login.gov account with MFA required)
# Create account at: https://datawebws.usitc.gov/dataweb/
USITC_DATAWEB_USERNAME=your_login_gov_username
USITC_DATAWEB_PASSWORD=your_login_gov_password
USITC_DATAWEB_API_URL=https://datawebws.usitc.gov/dataweb

# =================================================================
# EMAIL SERVICE CONFIGURATION
# =================================================================
# SMTP Configuration - Choose one provider below

# Option 1: Resend (Recommended for production)
RESEND_API_KEY=re_your_resend_api_key

# Option 2: Generic SMTP (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Option 3: SendGrid SMTP
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key

# =================================================================
# SMS NOTIFICATIONS (Optional)
# =================================================================
# Twilio for SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# =================================================================
# MONITORING AND PERFORMANCE
# =================================================================
API_RATE_LIMIT_PER_MINUTE=100
CACHE_TTL_SECONDS=300
MAX_TARIFF_REQUESTS_PER_DAY=1000
DATABASE_CONNECTION_POOL_MAX=10
DATABASE_CONNECTION_POOL_MIN=2
LOG_LEVEL=info

# =================================================================
# STRIPE PAYMENT PROCESSING
# =================================================================
# Get these from your Stripe dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs for subscription plans
STRIPE_PROFESSIONAL_PRICE_ID=price_your_professional_plan_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_plan_id

# =================================================================
# OPTIONAL SERVICES
# =================================================================
ENABLE_API_MOCKING=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Monitoring services
SENTRY_DSN=your_sentry_dsn
GOOGLE_ANALYTICS_ID=your_ga_id