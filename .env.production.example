# =================================================================
# GOVERNMENT APIs (PRODUCTION)
# =================================================================
NEXT_PUBLIC_FEDERAL_REGISTER_API_URL=https://www.federalregister.gov/api/v1
FEDERAL_REGISTER_API_KEY=your_production_federal_register_key
COMMERCE_API_KEY=your_production_commerce_api_key
CUSTOMS_API_KEY=your_production_customs_api_key
TRADE_API_KEY=your_production_trade_api_key
CENSUS_API_KEY=your_production_census_api_key

# =================================================================
# EXTERNAL SERVICES (PRODUCTION)
# =================================================================
