GOOGLE_ANALYTICS_ID=your_production_ga_measurement_id

# =================================================================
# PRODUCTION FEATURE FLAGS
# =================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_DEVELOPMENT_MODE=false

# =================================================================
# PERFORMANCE & SCALING (PRODUCTION)
# =================================================================
API_RATE_LIMIT_PER_MINUTE=500
CACHE_TTL_SECONDS=900
MAX_TARIFF_REQUESTS_PER_DAY=10000
DATABASE_CONNECTION_POOL_MAX=20
DATABASE_CONNECTION_POOL_MIN=5
LOG_LEVEL=warn

# =================================================================
# CACHING (PRODUCTION)
# =================================================================
REDIS_URL=your_production_redis_url
REDIS_PASSWORD=your_production_redis_password